# ─── DocAI Configuration ───────────────────────────────────────
# Set at least ONE provider API key below.
# DocAI auto-detects which provider to use based on the model you select.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ─── Model Selection ──────────────────────────────────────────
# OpenAI:    gpt-4o, gpt-4.1-mini, gpt-5-mini, o3-mini
# Anthropic: claude-sonnet-4-6, claude-haiku-4-5, claude-opus-4-6
# Google:    gemini-2.5-pro, gemini-2.5-flash
DOCAI_MODEL=gpt-4o

# ─── Optional Settings ────────────────────────────────────────
DOCAI_EMBEDDING_MODEL=text-embedding-ada-002
DOCAI_MAX_TOKENS=100000
DOCAI_CHROMA_DIR=./.chroma_db
